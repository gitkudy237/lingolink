{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@lingolink/shared": ["../shared/src"],
      "@lingolink/shared/*": ["../shared/src/*"]
    }
  },
  "expo": {
    "typedRoutes": false
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
