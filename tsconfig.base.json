{
  "compilerOptions": {
    "target": "ES2020",
    "baseUrl": ".",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@lingolink/shared": ["shared/src"],
      "@lingolink/shared/*": ["shared/src/*"]
    },
    "ignoreDeprecations": "6.0"
  }
}
